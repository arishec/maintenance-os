generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserTypeHint {
  homeowner
  landlord
}

enum PropertyType {
  single_family
  condo
  apartment
  townhouse
  duplex
  other
}

enum Trade {
  plumbing
  electrical
  hvac
  roofing
  appliance_repair
  handyman
  pest_control
  landscaping
  cleaning
  restoration
  general_contractor
  other
}

enum IssueCategory {
  plumbing
  electrical
  hvac
  roofing
  appliance
  structural
  pest
  cleaning
  exterior
  general_handyman
  unknown
}

enum Urgency {
  emergency
  high
  medium
  low
}

enum SuggestedTimeframe {
  immediately
  today
  within_24_hours
  within_2_to_3_days
  within_1_week
}

enum IssueStatus {
  new
  classified
  awaiting_dispatch
  awaiting_quotes
  quotes_received
  contractor_selected
  scheduled
  in_progress
  completed
  canceled
  archived
}

enum DispatchChannel {
  sms
  email
}

enum DispatchStatus {
  queued
  sent
  delivered
  failed
  replied
  expired
}

enum JobStatus {
  contractor_selected
  scheduled
  in_progress
  completed
  canceled
}

model User {
  id            String         @id @default(uuid())
  clerkUserId   String         @unique
  email         String         @unique
  fullName      String?
  userTypeHint  UserTypeHint?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  properties    Property[]
  contractors   Contractor[]
  issues        Issue[]        @relation("IssueReporter")
  notifications Notification[]
}

model Property {
  id              String               @id @default(uuid())
  ownerUserId     String
  nickname        String?
  addressLine1    String
  addressLine2    String?
  city            String
  state           String
  postalCode      String
  propertyType    PropertyType
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  owner           User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  issues          Issue[]
  propertyLinks   PropertyIntakeLink[]
  propertyWorkers PropertyContractor[]
  timelineEvents  TimelineEvent[]
}

model Contractor {
  id                String               @id @default(uuid())
  ownerUserId       String
  name              String
  companyName       String?
  trade             Trade
  phone             String?
  email             String?
  notes             String?
  isPreferred       Boolean              @default(false)
  isArchived        Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  owner             User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  propertyLinks     PropertyContractor[]
  dispatches        Dispatch[]
  jobs              Job[]
}

model PropertyContractor {
  id           String     @id @default(uuid())
  propertyId   String
  contractorId String
  createdAt    DateTime   @default(now())
  property     Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@unique([propertyId, contractorId])
}

model Issue {
  id                 String              @id @default(uuid())
  propertyId         String
  reportedByUserId   String?
  reporterName       String?
  reporterContact    String?
  sourceType         String
  title              String?
  description        String
  locationInProperty String?
  category           IssueCategory?
  subcategory        String?
  urgency            Urgency?
  reasoningSummary   String?
  suggestedTimeframe SuggestedTimeframe?
  recommendedTrade   Trade?
  aiConfidence       Decimal?            @db.Decimal(5,4)
  status             IssueStatus         @default(new)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  completedAt        DateTime?
  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reporter           User?               @relation("IssueReporter", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  photos             IssuePhoto[]
  dispatches         Dispatch[]
  jobs               Job[]
  timelineEvents     TimelineEvent[]
  usageMetrics       UsageMetricsIssueCost?
}

model IssuePhoto {
  id        String   @id @default(uuid())
  issueId    String
  filePath   String
  fileUrl    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model Dispatch {
  id                String              @id @default(uuid())
  issueId           String
  contractorId      String
  channel           DispatchChannel
  outboundMessage   String
  status            DispatchStatus      @default(queued)
  providerMessageId String?
  replyToken        String?             @unique
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  replyReceivedAt   DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  issue             Issue               @relation(fields: [issueId], references: [id], onDelete: Cascade)
  contractor        Contractor          @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  responses         ContractorResponse[]
}

model ContractorResponse {
  id                   String    @id @default(uuid())
  dispatchId           String
  rawMessage           String
  availabilityText     String?
  availabilityDate     DateTime?
  estimateLow          Decimal?  @db.Decimal(10,2)
  estimateHigh         Decimal?  @db.Decimal(10,2)
  flatEstimate         Decimal?  @db.Decimal(10,2)
  notes                String?
  followUpQuestion     String?
  extractionConfidence Decimal?  @db.Decimal(5,4)
  requiresReview       Boolean   @default(false)
  receivedAt           DateTime
  createdAt            DateTime  @default(now())
  dispatch             Dispatch  @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  jobs                 Job[]
}

model Job {
  id                 String              @id @default(uuid())
  issueId            String
  contractorId       String
  selectedResponseId String?
  selectedEstimate   Decimal?            @db.Decimal(10,2)
  scheduledFor       DateTime?
  status             JobStatus
  notes              String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  issue              Issue               @relation(fields: [issueId], references: [id], onDelete: Cascade)
  contractor         Contractor          @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  selectedResponse   ContractorResponse? @relation(fields: [selectedResponseId], references: [id], onDelete: SetNull)
  timelineEvents     TimelineEvent[]
}

model TimelineEvent {
  id               String    @id @default(uuid())
  propertyId       String
  issueId          String?
  jobId            String?
  actorType        String
  actorLabel       String?
  eventType        String
  eventPayloadJson Json?
  createdAt        DateTime  @default(now())
  property         Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  issue            Issue?    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  job              Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model PropertyIntakeLink {
  id        String   @id @default(uuid())
  propertyId String
  tokenHash String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  rotatedAt DateTime?
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageMetricsIssueCost {
  id                 String   @id @default(uuid())
  issueId            String   @unique
  outboundSmsCount   Int      @default(0)
  inboundSmsCount    Int      @default(0)
  outboundEmailCount Int      @default(0)
  aiRequestCount     Int      @default(0)
  estimatedSmsCost   Decimal  @default(0) @db.Decimal(10,4)
  estimatedEmailCost Decimal  @default(0) @db.Decimal(10,4)
  estimatedAiCost    Decimal  @default(0) @db.Decimal(10,4)
  estimatedTotalCost Decimal  @default(0) @db.Decimal(10,4)
  updatedAt          DateTime @updatedAt
  issue              Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

model UnresolvedInboundMessage {
  id              String    @id @default(uuid())
  provider        String
  sender          String?
  subject         String?
  rawBody         String
  matchedToken    String?
  receivedAt      DateTime  @default(now())
  resolvedAt      DateTime?
  resolutionNotes String?
}
